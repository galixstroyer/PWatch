def spawn_bpftrace_network(output_dir: Path) -> ToolProcess | None:
    if shutil.which("bpftrace") is None:
        return None
    script_path = output_dir / "ebpf-network.bt"
    script_path.write_text(ebpf_network_program())
    cmd = ["bpftrace", "-q", str(script_path)]
    proc = subprocess.Popen(
        cmd,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
        bufsize=1,
    )
    return ToolProcess("bpftrace-network", proc, str(script_path))


def parse_ebpf_network_line(line: str) -> dict[str, Any] | None:
    line = line.strip()
    if not line.startswith("NET|"):
        return None
    parts = line.split("|", 5)
    if len(parts) != 6:
        return None
    _, pid_text, tid_text, comm, op, payload = parts
    try:
        pid = int(pid_text)
        tid = int(tid_text)
    except ValueError:
        return None

    fields: dict[str, Any] = {}
    for token in shlex.split(payload):
        if "=" not in token:
            continue
        key, value = token.split("=", 1)
        try:
            fields[key] = int(value)
        except ValueError:
            fields[key] = value

    return {
        "pid": pid,
        "tid": tid,
        "comm": comm,
        "op": op,
        "fields": fields,
        "raw": line,
    }


def collect_ebpf_network(
    root_pid: int,
    tool: ToolProcess,
    session: Session,
    stop_event: threading.Event,
    stats: dict[str, Any],
) -> None:
    stats["event_count"] = 0
    stats["filtered_count"] = 0

    if tool.proc.stdout is None:
        return

    while not stop_event.is_set():
        line = tool.proc.stdout.readline()
        if not line:
            if tool.proc.poll() is not None:
                break
            continue
        event = parse_ebpf_network_line(line)
        if event is None:
            continue
        stats["event_count"] += 1

        if not is_in_process_tree(root_pid, event["pid"]):
            continue

        stats["filtered_count"] += 1
        session.event("ebpf_network", root_pid=root_pid, **event)

def terminate_tool(tool: ToolProcess, session: Session) -> None:
    if tool.proc.poll() is None:
        tool.proc.terminate()
        try:
            tool.proc.wait(timeout=3)
        except subprocess.TimeoutExpired:
            tool.proc.kill()
    stderr = ""
    if tool.proc.stderr is not None:
        stderr = tool.proc.stderr.read()
    session.event(
        "tool_exit",
        tool=tool.name,
        returncode=tool.proc.returncode,
        output=tool.output,
        stderr=stderr.strip(),
    )


def monitor_loop(
    root_pid: int,
    session: Session,
    include_env: bool,
    interval: float,
    stop_event: threading.Event,
) -> dict[str, Any]:
    snapshot_count = 0
    last_tree: list[int] = []
    last_status = 0.0
    endpoint_rollups: dict[str, dict[str, Any]] = {}
    while not stop_event.is_set():
        if not Path(f"/proc/{root_pid}").exists():
            session.event("process_exit", pid=root_pid)
            console(f"[pwatch] target exited: pid={root_pid}")
            break

        sample_ts = utc_now()
        pids = process_tree(root_pid)
        last_tree = pids
        proc_data = []
        socket_rows: list[dict[str, Any]] = []
        proc_net = read_proc_net_by_inode()
        for pid in pids:
            if Path(f"/proc/{pid}").exists():
                snapshot = read_process_snapshot(pid, include_env)
                proc_data.append(snapshot)
                for inode in socket_inodes_from_fd_links(snapshot["fd_links"]):
                    row = proc_net.get(inode)
                    if row:
                        socket_row = {"pid": pid, **row}
                        socket_rows.append(socket_row)
                        update_endpoint_rollups(
                            endpoint_rollups,
                            pid=pid,
                            proto=row.get("proto", "unknown"),
                            local=row.get("local"),
                            remote=row.get("remote"),
                            source="proc_net",
                            ts=sample_ts,
                        )

        lsof_rows: list[dict[str, Any]] = []
        for pid in pids:
            lsof_result = run_capture(["lsof", "-nP", "-p", str(pid)], timeout=5)
            if lsof_result.get("ok"):
                lsof_rows.extend(parse_lsof_output(lsof_result["stdout"]))

        ss_result = run_capture(["ss", "-tpna"], timeout=5)
        ss_rows = parse_ss_output(ss_result.get("stdout", ""), set(pids)) if ss_result.get("stdout") else []
        for row in ss_rows:
            matched_pid = row.get("matched_pid")
            if matched_pid is None:
                continue
            update_endpoint_rollups(
                endpoint_rollups,
                pid=matched_pid,
                proto="tcp",
                local=row.get("local"),
                remote=row.get("peer"),
                source="ss",
                ts=sample_ts,
            )

        session.event(
            "snapshot",
            root_pid=root_pid,
            pids=pids,
            processes=proc_data,
            proc_net=socket_rows,
            lsof=lsof_rows,
            ss=ss_rows,
        )
        snapshot_count += 1
        now = time.time()
        if now - last_status >= max(1.0, interval):
            console(
                "[pwatch] snapshot="
                f"{snapshot_count} root_pid={root_pid} pids={len(pids)} "
                f"sockets={len(socket_rows)} ss={len(ss_rows)} lsof={len(lsof_rows)}"
            )
            last_status = now
        stop_event.wait(interval)

    return {
        "snapshot_count": snapshot_count,
        "last_tree": last_tree,
        "endpoint_rollups": list(endpoint_rollups.values()),
    }


def signal_name(sig: int) -> str:
    try:
        return signal.Signals(sig).name
    except ValueError:
        return str(sig)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="pwatch",
        description="Observe a Linux process tree with /proc snapshots, strace, lsof, ss, and optional pcap.",
        epilog=(
            "Examples:\n"
            "  pwatch run -- curl https://example.com\n"
            "  pwatch --duration 15 attach 12345\n"
            "  sudo pwatch --pcap --pcap-filter \"tcp port 443\" attach 12345\n\n"
            "Notes:\n"
            "  - run mode is best when you can start the target yourself.\n"
            "  - proc_net, ss, lsof, and strace data are correlated to the PID tree.\n"
            "  - --pcap captures host packets and may include traffic from other processes."
        ),
        formatter_class=argparse.RawTextHelpFormatter,
    )
    parser.add_argument(
        "--save",
        action="store_true",
        help="Persist capture artifacts to disk. Without this flag, capture files are kept in a temporary directory and deleted on exit.",
    )
    parser.add_argument("--output", default=None, help="Output directory when --save is used. Defaults to ./pwatch-<timestamp>.")
    parser.add_argument(
        "--events-file",
        default=None,
        help="Optional explicit path for the JSONL event stream. Defaults to <output>/events.jsonl.",
    )
    parser.add_argument(
        "--summary-file",
        default=None,
        help="Optional explicit path for the final summary JSON. Defaults to <output>/summary.json.",
    )
    parser.add_argument("--interval", type=float, default=1.0, help="Snapshot interval in seconds.")
    parser.add_argument("--duration", type=float, default=None, help="Optional max runtime in seconds.")
    parser.add_argument("--include-env", action="store_true", help="Capture process environments from /proc/<pid>/environ.")
    parser.add_argument(
        "--trace-mode",
        choices=["network", "broad"],
        default="broad",
        help="Use network-only syscall tracing or a broader syscall set.",
    )
    parser.add_argument("--string-bytes", type=int, default=4096, help="Max string bytes for strace decoding.")
    parser.add_argument(
        "--ebpf-network",
        action="store_true",
        help="Use bpftrace/eBPF to collect high-frequency network syscall events. Requires root.",
    )
    parser.add_argument("--pcap", action="store_true", help="Capture host-level packets to traffic.pcap with tcpdump.")
    parser.add_argument(
        "--pcap-filter",
        default=None,
        help="Optional tcpdump BPF filter, for example: tcp port 443",
    )

    subparsers = parser.add_subparsers(dest="mode", required=True)

    attach = subparsers.add_parser("attach", help="Attach to an existing PID.")
    attach.add_argument("pid", type=int, help="PID to observe.")

    run = subparsers.add_parser("run", help="Start a command, then observe it.")
    run.add_argument("command", nargs=argparse.REMAINDER, help="Command to run. Use: pwatch run -- <cmd> ...")

    return parser


def resolve_output_dir(raw: str | None) -> Path:
    if raw:
        return Path(raw).expanduser().resolve()
    stamp = datetime.now().strftime("%Y%m%d-%H%M%S")
    return Path.cwd() / f"pwatch-{stamp}"


def main() -> int:
    args = build_parser().parse_args()
    if not args.save and (args.output or args.events_file or args.summary_file or args.pcap):
        print("--output, --events-file, --summary-file, and --pcap require --save.", file=sys.stderr)
        return 2

    temp_dir: tempfile.TemporaryDirectory[str] | None = None
    if args.save:
        output_dir = resolve_output_dir(args.output)
    else:
        temp_dir = tempfile.TemporaryDirectory(prefix="pwatch-")
        output_dir = Path(temp_dir.name).resolve()
    session = Session(output_dir, args.events_file, args.summary_file)
    stop_event = threading.Event()
    root_pid: int
    target_proc: subprocess.Popen[str] | None = None
    tools: list[ToolProcess] = []
    summary: dict[str, Any] = {
        "started_at": utc_now(),
        "mode": args.mode,
        "output_dir": str(output_dir),
        "events_file": str(session.events_path),
        "summary_file": str(session.summary_path),
        "hostname": os.uname().nodename,
    }
    pending_ebpf_tool: ToolProcess | None = None
    pending_tcpdump_tool: ToolProcess | None = None
    if args.ebpf_network and os.geteuid() == 0 and args.mode == "run":
        pending_ebpf_tool = spawn_bpftrace_network(output_dir)
    if args.pcap and args.mode == "run":
        pending_tcpdump_tool = spawn_tcpdump(output_dir, args.pcap_filter)

    if args.mode == "run":
        command = args.command
        if command and command[0] == "--":
            command = command[1:]
        if not command:
            print("pwatch run requires a command. Example: pwatch run -- curl https://example.com", file=sys.stderr)
            return 2
        summary["command"] = command
        strace_tool, pid_file = spawn_command_under_strace(command, output_dir, args.trace_mode, args.string_bytes)
        if strace_tool is None:
            target_proc = subprocess.Popen(command, text=True)
            root_pid = target_proc.pid
        else:
            tools.append(strace_tool)
            session.event("tool_start", tool="strace", output=strace_tool.output)
            deadline = time.time() + 5
            pid_text = None
            while time.time() < deadline:
                pid_text = safe_text(pid_file)
                if pid_text:
                    break
                if strace_tool.proc.poll() is not None:
                    break
                time.sleep(0.05)
            if not pid_text:
                stderr = ""
                if strace_tool.proc.stderr is not None:
                    stderr = strace_tool.proc.stderr.read().strip()
                print("Unable to determine spawned PID. Check strace permissions.", file=sys.stderr)
                if stderr:
                    print(stderr, file=sys.stderr)
                return 1
            root_pid = int(pid_text)
    else:
        root_pid = args.pid
        if not Path(f"/proc/{root_pid}").exists():
            print(f"PID {root_pid} does not exist.", file=sys.stderr)
            return 1

    session.write_json(
        "metadata.json",
        {
            **summary,
            "root_pid": root_pid,
            "interval_seconds": args.interval,
            "duration_seconds": args.duration,
            "include_env": args.include_env,
            "trace_mode": args.trace_mode,
            "string_bytes": args.string_bytes,
            "ebpf_network": args.ebpf_network,
            "pcap": args.pcap,
            "pcap_filter": args.pcap_filter,
            "events_file": str(session.events_path),
            "summary_file": str(session.summary_path),
        },
    )
    session.event("session_start", root_pid=root_pid, mode=args.mode)
    console(f"[pwatch] mode={args.mode} root_pid={root_pid}")
    if args.save:
        console(f"[pwatch] output_dir={output_dir}")
        console(f"[pwatch] events_file={session.events_path}")
        console(f"[pwatch] summary_file={session.summary_path}")
    else:
        console("[pwatch] save=off temporary capture will be deleted on exit")
    if args.mode == "attach" and args.duration is None:
        console("[pwatch] attach is running until you press Ctrl-C")
    if args.ebpf_network and os.geteuid() != 0:
        console("[pwatch] warning: --ebpf-network requires root; run with sudo")

    def stop_handler(signum: int, _frame: Any) -> None:
        session.event("signal", signal=signal_name(signum))
        console(f"[pwatch] stopping on signal={signal_name(signum)}")
        stop_event.set()
        if target_proc is not None and target_proc.poll() is None:
            target_proc.terminate()

    signal.signal(signal.SIGINT, stop_handler)
    signal.signal(signal.SIGTERM, stop_handler)

    if args.mode == "attach":
        strace_tool = spawn_strace(root_pid, output_dir, args.trace_mode, args.string_bytes)
        if strace_tool is None:
            session.event("warning", message="strace is not available")
            console("[pwatch] warning: strace is not available")
        else:
            tools.append(strace_tool)
            session.event("tool_start", tool="strace", output=strace_tool.output)
            console(f"[pwatch] strace output={strace_tool.output}")

    ebpf_stats: dict[str, Any] = {}
    ebpf_thread: threading.Thread | None = None
    if args.ebpf_network:
        if os.geteuid() != 0:
            session.event("warning", message="--ebpf-network requires root")
        else:
            ebpf_tool = pending_ebpf_tool if pending_ebpf_tool is not None else spawn_bpftrace_network(output_dir)
            if ebpf_tool is None:
                session.event("warning", message="bpftrace is not available")
                console("[pwatch] warning: bpftrace is not available")
            else:
                tools.append(ebpf_tool)
                session.event("tool_start", tool="bpftrace-network", output=ebpf_tool.output)
                console(f"[pwatch] bpftrace script={ebpf_tool.output}")
                ebpf_thread = threading.Thread(
                    target=collect_ebpf_network,
                    args=(root_pid, ebpf_tool, session, stop_event, ebpf_stats),
                    daemon=True,
                )
                ebpf_thread.start()

    if args.pcap:
        tcpdump_tool = pending_tcpdump_tool if pending_tcpdump_tool is not None else spawn_tcpdump(output_dir, args.pcap_filter)
        if tcpdump_tool is None:
            session.event("warning", message="tcpdump is not available")
            console("[pwatch] warning: tcpdump is not available")
        else:
            tools.append(tcpdump_tool)
            session.event("tool_start", tool="tcpdump", output=tcpdump_tool.output)
            console(f"[pwatch] tcpdump output={tcpdump_tool.output}")

    monitor_result: dict[str, Any] = {}
    monitor_thread = threading.Thread(
        target=lambda: monitor_result.update(
            monitor_loop(root_pid, session, args.include_env, args.interval, stop_event)
        ),
        daemon=True,
    )
    monitor_thread.start()

    deadline = time.time() + args.duration if args.duration else None
    try:
        while not stop_event.is_set():
            if target_proc is not None and target_proc.poll() is not None:
                session.event("process_exit", pid=root_pid, returncode=target_proc.returncode)
                stop_event.set()
                break
            if args.mode == "run" and target_proc is None and not Path(f"/proc/{root_pid}").exists():
                stop_event.set()
                break
            if deadline is not None and time.time() >= deadline:
                session.event("duration_reached", seconds=args.duration)
                stop_event.set()
                if target_proc is not None and target_proc.poll() is None:
                    target_proc.terminate()
                break
            if not Path(f"/proc/{root_pid}").exists():
                stop_event.set()
                break
            time.sleep(0.2)
    finally:
        stop_event.set()
        monitor_thread.join(timeout=max(1.0, args.interval * 2))
        if ebpf_thread is not None:
            ebpf_thread.join(timeout=2)
        for tool in tools:
            terminate_tool(tool, session)
        if target_proc is not None and target_proc.poll() is None:
            target_proc.terminate()
            try:
                target_proc.wait(timeout=3)
            except subprocess.TimeoutExpired:
                target_proc.kill()

    summary.update(
        {
            "finished_at": utc_now(),
            "root_pid": root_pid,
            "snapshot_count": monitor_result.get("snapshot_count", 0),
            "last_seen_pids": monitor_result.get("last_tree", []),
            "ebpf_event_count": ebpf_stats.get("filtered_count", 0),
            "ebpf_raw_event_count": ebpf_stats.get("event_count", 0),
            "target_returncode": (
                target_proc.returncode
                if target_proc is not None
                else next((tool.proc.returncode for tool in tools if tool.name == "strace"), None)
            ),
        }
    )

    endpoint_summary: list[dict[str, Any]] = []
    dns_summary: list[dict[str, Any]] = []
    tls_sni_summary: list[dict[str, Any]] = []
    if args.save:
        resolver = EndpointResolver()
        pcap_path = output_dir / "traffic.pcap"
        dns_summary = extract_dns_from_pcap(pcap_path) if args.pcap else []
        tls_sni_summary = extract_tls_sni_from_pcap(pcap_path) if args.pcap else []
        pcap_endpoints = extract_endpoints_from_pcap(pcap_path) if args.pcap else []
        endpoint_rollups = {
            endpoint_key(row["pid"], row["proto"], row["remote"]): row
            for row in monitor_result.get("endpoint_rollups", [])
        }
        endpoint_summary = finalize_endpoint_rollups(
            endpoint_rollups,
            resolver,
            dns_summary,
            tls_sni_summary,
            pcap_endpoints,
        )
        session.write_json("endpoint_summary.json", endpoint_summary)
        session.write_json("dns_summary.json", dns_summary)
        session.write_json("tls_sni_summary.json", tls_sni_summary)

    summary.update(
        {
            "endpoint_count": len(endpoint_summary),
            "dns_record_count": len(dns_summary),
            "tls_sni_count": len(tls_sni_summary),
        }
    )
    session.write_json("summary.json", summary)
    if args.save:
        console(
            "[pwatch] finished "
            f"root_pid={root_pid} snapshots={summary['snapshot_count']} "
            f"summary_file={session.summary_path}"
        )
        print(output_dir)
    else:
        console(
            "[pwatch] finished "
            f"root_pid={root_pid} snapshots={summary['snapshot_count']} save=off"
        )
    if temp_dir is not None:
        temp_dir.cleanup()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
