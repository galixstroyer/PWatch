SOCKET_RE = re.compile(r"socket:\[(\d+)\]")


def utc_now() -> str:
    return datetime.now(timezone.utc).isoformat()


def safe_text(path: Path, strip: bool = True) -> str | None:
    try:
        data = path.read_text(errors="replace")
    except OSError:
        return None
    return data.strip() if strip else data


def safe_link(path: Path) -> str | None:
    try:
        return os.readlink(path)
    except OSError:
        return None


def read_cmdline(pid: int) -> list[str]:
    path = Path(f"/proc/{pid}/cmdline")
    try:
        raw = path.read_bytes()
    except OSError:
        return []
    return [part.decode(errors="replace") for part in raw.split(b"\0") if part]


def list_all_pids() -> list[int]:
    pids: list[int] = []
    for entry in Path("/proc").iterdir():
        if entry.name.isdigit():
            pids.append(int(entry.name))
    return pids


def process_tree(root_pid: int) -> list[int]:
    children_by_parent: dict[int, list[int]] = {}
    for pid in list_all_pids():
        status = safe_text(Path(f"/proc/{pid}/status"))
        if not status:
            continue
        parent = None
        for line in status.splitlines():
            if line.startswith("PPid:"):
                try:
                    parent = int(line.split()[1])
                except (IndexError, ValueError):
                    parent = None
                break
        if parent is not None:
            children_by_parent.setdefault(parent, []).append(pid)

    ordered: list[int] = []
    stack = [root_pid]
    seen: set[int] = set()
    while stack:
        pid = stack.pop()
        if pid in seen:
            continue
        seen.add(pid)
        ordered.append(pid)
        stack.extend(sorted(children_by_parent.get(pid, []), reverse=True))
    return sorted(ordered)


def process_parent(pid: int) -> int | None:
    status = safe_text(Path(f"/proc/{pid}/status"))
    if not status:
        return None
    for line in status.splitlines():
        if line.startswith("PPid:"):
            try:
                return int(line.split()[1])
            except (IndexError, ValueError):
                return None
    return None


def is_in_process_tree(root_pid: int, pid: int) -> bool:
    current = pid
    seen: set[int] = set()
    while current not in seen and current > 0:
        if current == root_pid:
            return True
        seen.add(current)
        parent = process_parent(current)
        if parent is None:
            return False
        current = parent
    return False


def run_capture(cmd: list[str], timeout: float = 5.0) -> dict[str, Any]:
    try:
        proc = subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            timeout=timeout,
            check=False,
        )
    except FileNotFoundError:
        return {"ok": False, "missing": True, "cmd": cmd}
    except subprocess.TimeoutExpired as exc:
        return {
            "ok": False,
            "timeout": True,
            "cmd": cmd,
            "stdout": exc.stdout or "",
            "stderr": exc.stderr or "",
        }
    return {
        "ok": proc.returncode == 0,
        "cmd": cmd,
        "returncode": proc.returncode,
        "stdout": proc.stdout,
        "stderr": proc.stderr,
    }


def split_host_port(value: str) -> tuple[str | None, int | None]:
    if not value or value in {"*", "*:*"}:
        return None, None
    if value.startswith("[") and "]:" in value:
        host, port_text = value[1:].rsplit("]:", 1)
    elif value.count(":") >= 2:
        host, port_text = value.rsplit(":", 1)
    elif ":" in value:
        host, port_text = value.rsplit(":", 1)
    else:
        return value, None
    try:
        return host, int(port_text)
    except ValueError:
        return host, None


def normalize_ip(ip: str | None) -> str | None:
    if not ip:
        return None
    if ip == "*" or ip == "0.0.0.0" or ip == "::":
        return None
    return ip


class EndpointResolver:
    def __init__(self) -> None:
        self.cache: dict[str, list[str]] = {}

    def resolve(self, ip: str | None) -> list[str]:
        if ip is None:
            return []
        if ip in self.cache:
            return self.cache[ip]

        names: list[str] = []
        result = run_capture(["getent", "hosts", ip], timeout=2)
        if result.get("ok"):
            for line in result.get("stdout", "").splitlines():
                parts = line.split()
                if len(parts) >= 2:
                    hostname = parts[1]
                    if hostname != ip and hostname not in names:
                        names.append(hostname)
        self.cache[ip] = names
        return names


def endpoint_key(pid: int, proto: str, remote: str) -> str:
    return f"{pid}|{proto}|{remote}"


def update_endpoint_rollups(
    rollups: dict[str, dict[str, Any]],
    *,
    pid: int,
    proto: str,
    local: str | None,
    remote: str | None,
    source: str,
    ts: str,
) -> None:
    if not remote:
        return
    remote_ip, remote_port = split_host_port(remote)
    remote_ip = normalize_ip(remote_ip)
    if remote_ip is None or remote_port in {None, 0}:
        return
    local_ip, local_port = split_host_port(local or "")
    key = endpoint_key(pid, proto, remote)
    row = rollups.setdefault(
        key,
        {
            "pid": pid,
            "proto": proto,
            "remote": remote,
            "remote_ip": remote_ip,
            "remote_port": remote_port,
            "local": local,
            "local_ip": normalize_ip(local_ip),
            "local_port": local_port,
            "sources": [],
            "first_seen": ts,
            "last_seen": ts,
            "seen_count": 0,
        },
    )
    row["last_seen"] = ts
    row["seen_count"] += 1
    if source not in row["sources"]:
        row["sources"].append(source)
    if not row.get("local") and local:
        row["local"] = local
        row["local_ip"] = normalize_ip(local_ip)
        row["local_port"] = local_port


def extract_dns_from_pcap(pcap_path: Path) -> list[dict[str, Any]]:
    if shutil.which("tshark") is None or not pcap_path.exists():
        return []
    result = run_capture(
        [
            "tshark",
            "-r",
            str(pcap_path),
            "-Y",
            "dns",
            "-T",
            "fields",
            "-E",
            "header=n",
            "-E",
            "separator=\t",
            "-e",
            "frame.time_epoch",
            "-e",
            "ip.src",
            "-e",
            "ipv6.src",
            "-e",
            "ip.dst",
            "-e",
            "ipv6.dst",
            "-e",
            "dns.flags.response",
            "-e",
            "dns.qry.name",
            "-e",
            "dns.resp.name",
            "-e",
            "dns.a",
            "-e",
            "dns.aaaa",
        ],
        timeout=15,
    )
    if not result.get("ok"):
        return []

    records: list[dict[str, Any]] = []
    for line in result.get("stdout", "").splitlines():
        parts = line.split("\t")
        if len(parts) < 10:
            continue
        ts, ip_src, ipv6_src, ip_dst, ipv6_dst, is_response, qry_name, resp_name, a_recs, aaaa_recs = parts[:10]
        src = ip_src or ipv6_src or None
        dst = ip_dst or ipv6_dst or None
        answers = [value for value in (a_recs.split(",") + aaaa_recs.split(",")) if value]
        record = {
            "ts_epoch": ts,
            "src": src,
            "dst": dst,
            "is_response": is_response == "1",
            "query": qry_name or None,
            "response_name": resp_name or None,
            "answers": answers,
        }
        records.append(record)
    return records


def extract_tls_sni_from_pcap(pcap_path: Path) -> list[dict[str, Any]]:
    if shutil.which("tshark") is None or not pcap_path.exists():
        return []
    result = run_capture(
        [
            "tshark",
            "-r",
            str(pcap_path),
            "-Y",
            "tls.handshake.extensions_server_name",
            "-T",
            "fields",
            "-E",
            "header=n",
            "-E",
            "separator=\t",
            "-e",
            "frame.time_epoch",
            "-e",
            "ip.src",
            "-e",
            "ipv6.src",
            "-e",
            "tcp.srcport",
            "-e",
            "ip.dst",
            "-e",
            "ipv6.dst",
            "-e",
            "tcp.dstport",
            "-e",
            "tls.handshake.extensions_server_name",
        ],
        timeout=15,
    )
    if not result.get("ok"):
        return []

    records: list[dict[str, Any]] = []
    for line in result.get("stdout", "").splitlines():
        parts = line.split("\t")
        if len(parts) < 8:
            continue
        ts, ip_src, ipv6_src, src_port, ip_dst, ipv6_dst, dst_port, sni = parts[:8]
        if not sni:
            continue
        try:
            src_port_int = int(src_port) if src_port else None
        except ValueError:
            src_port_int = None
        try:
            dst_port_int = int(dst_port) if dst_port else None
        except ValueError:
            dst_port_int = None
        records.append(
            {
                "ts_epoch": ts,
                "src": ip_src or ipv6_src or None,
                "src_port": src_port_int,
                "dst": ip_dst or ipv6_dst or None,
                "dst_port": dst_port_int,
                "sni": sni,
            }
        )
    return records


def extract_endpoints_from_pcap(pcap_path: Path) -> list[dict[str, Any]]:
    if shutil.which("tshark") is None or not pcap_path.exists():
        return []
    result = run_capture(
        [
            "tshark",
            "-r",
            str(pcap_path),
            "-T",
            "fields",
            "-E",
            "header=n",
            "-E",
            "separator=\t",
            "-e",
            "frame.time_epoch",
            "-e",
            "ip.src",
            "-e",
            "ipv6.src",
            "-e",
            "tcp.srcport",
            "-e",
            "udp.srcport",
            "-e",
            "ip.dst",
            "-e",
            "ipv6.dst",
            "-e",
            "tcp.dstport",
            "-e",
            "udp.dstport",
        ],
        timeout=15,
    )
    if not result.get("ok"):
        return []

    rows: list[dict[str, Any]] = []
    for line in result.get("stdout", "").splitlines():
        parts = line.split("\t")
        if len(parts) < 9:
            continue
        ts, ip_src, ipv6_src, tcp_src, udp_src, ip_dst, ipv6_dst, tcp_dst, udp_dst = parts[:9]
        src = ip_src or ipv6_src or None
        dst = ip_dst or ipv6_dst or None
        proto = "tcp" if tcp_dst else "udp" if udp_dst else None
        src_port = tcp_src or udp_src or None
        dst_port = tcp_dst or udp_dst or None
        if not proto or not src or not dst or not dst_port:
            continue
        try:
            src_port_int = int(src_port) if src_port else None
            dst_port_int = int(dst_port)
        except ValueError:
            continue
        rows.append(
            {
                "ts_epoch": ts,
                "proto": proto,
                "local_ip": src,
                "local_port": src_port_int,
                "remote_ip": dst,
                "remote_port": dst_port_int,
            }
        )
    return rows


def finalize_endpoint_rollups(
    rollups: dict[str, dict[str, Any]],
    resolver: EndpointResolver,
    dns_records: list[dict[str, Any]],
    tls_sni_records: list[dict[str, Any]],
    pcap_endpoints: list[dict[str, Any]],
) -> list[dict[str, Any]]:
    dns_names_by_ip: dict[str, set[str]] = {}
    for record in dns_records:
        name = record.get("query") or record.get("response_name")
        if not name:
            continue
        for answer in record.get("answers", []):
            dns_names_by_ip.setdefault(answer, set()).add(name)

    sni_by_ip: dict[str, set[str]] = {}
    for record in tls_sni_records:
        dst = record.get("dst")
        sni = record.get("sni")
        if dst and sni:
            sni_by_ip.setdefault(dst, set()).add(sni)

    for record in pcap_endpoints:
        remote_ip = normalize_ip(record.get("remote_ip"))
        remote_port = record.get("remote_port")
        if remote_ip is None or remote_port in {None, 0}:
            continue
        key = endpoint_key(-1, record.get("proto", "unknown"), f"{remote_ip}:{remote_port}")
        row = rollups.setdefault(
            key,
            {
                "pid": None,
                "proto": record.get("proto", "unknown"),
                "remote": f"{remote_ip}:{remote_port}",
                "remote_ip": remote_ip,
                "remote_port": remote_port,
                "local": (
                    f"{record['local_ip']}:{record['local_port']}"
                    if record.get("local_ip") and record.get("local_port") is not None
                    else None
                ),
                "local_ip": normalize_ip(record.get("local_ip")),
                "local_port": record.get("local_port"),
                "sources": [],
                "first_seen": record.get("ts_epoch"),
                "last_seen": record.get("ts_epoch"),
                "seen_count": 0,
            },
        )
        row["seen_count"] += 1
        row["last_seen"] = record.get("ts_epoch")
        if "pcap" not in row["sources"]:
            row["sources"].append("pcap")

    rows: list[dict[str, Any]] = []
    for row in rollups.values():
        remote_ip = row.get("remote_ip")
        row = dict(row)
        row["reverse_dns"] = resolver.resolve(remote_ip)
        row["dns_names"] = sorted(dns_names_by_ip.get(remote_ip or "", set()))
        row["tls_sni"] = sorted(sni_by_ip.get(remote_ip or "", set()))
        rows.append(row)
    rows.sort(key=lambda item: (item["pid"] is None, item["pid"] or -1, item["remote_ip"], item["remote_port"]))
    return rows


def parse_lsof_output(text: str) -> list[dict[str, Any]]:
    rows: list[dict[str, Any]] = []
    lines = text.splitlines()
    if not lines:
        return rows
    for line in lines[1:]:
        parts = line.split()
        if len(parts) < 9:
            continue
        rows.append(
            {
                "command": parts[0],
                "pid": parts[1],
                "user": parts[2],
                "fd": parts[3],
                "type": parts[4],
                "device": parts[5],
                "size_off": parts[6],
                "node": parts[7],
                "name": " ".join(parts[8:]),
            }
        )
    return rows


def parse_ss_output(text: str, pids: set[int]) -> list[dict[str, Any]]:
    matches: list[dict[str, Any]] = []
    pending: dict[str, Any] | None = None
    for line in text.splitlines():
        if not line:
            continue
        if line[0].isspace():
            if pending is None:
                continue
            pending.setdefault("details", []).append(line.strip())
            for pid in pids:
                marker = f'pid={pid},'
                if marker in line or line.rstrip().endswith(f"pid={pid})"):
                    pending["matched_pid"] = pid
                    matches.append(pending)
                    pending = None
                    break
            continue

        parts = line.split()
        if len(parts) < 5 or parts[0] == "State":
            pending = None
            continue
        pending = {
            "state": parts[0],
            "recv_q": parts[1],
            "send_q": parts[2],
            "local": parts[3],
            "peer": parts[4],
        }
    return matches


def read_fd_links(pid: int) -> list[dict[str, Any]]:
    out: list[dict[str, Any]] = []
    fd_dir = Path(f"/proc/{pid}/fd")
    if not fd_dir.exists():
        return out
    for entry in sorted(fd_dir.iterdir(), key=lambda p: int(p.name)):
        out.append({"fd": entry.name, "target": safe_link(entry)})
    return out


def decode_ipv4(hex_ip: str) -> str:
    raw = bytes.fromhex(hex_ip)
    return ".".join(str(part) for part in raw[::-1])


def decode_ipv6(hex_ip: str) -> str:
    raw = bytes.fromhex(hex_ip)
    groups = [raw[index:index + 2] for index in range(0, 16, 2)]
    return ":".join(f"{int.from_bytes(group, 'big'):x}" for group in groups)


def decode_addr(raw: str, family: str) -> str:
    ip_hex, port_hex = raw.split(":")
    port = int(port_hex, 16)
    if family == "ipv6":
        return f"{decode_ipv6(ip_hex)}:{port}"
    return f"{decode_ipv4(ip_hex)}:{port}"


def parse_proc_net_table(path: Path, proto: str, family: str) -> list[dict[str, Any]]:
    text = safe_text(path, strip=False)
    if not text:
        return []
    rows: list[dict[str, Any]] = []
    lines = text.splitlines()
    for line in lines[1:]:
        parts = line.split()
        if len(parts) < 10:
            continue
        rows.append(
            {
                "proto": proto,
                "family": family,
                "local": decode_addr(parts[1], family),
                "remote": decode_addr(parts[2], family),
                "state": parts[3],
                "tx_queue": parts[4].split(":")[0],
                "rx_queue": parts[4].split(":")[1],
                "uid": parts[7],
                "inode": parts[9],
            }
        )
    return rows


def read_proc_net_by_inode() -> dict[str, dict[str, Any]]:
    tables = [
        (Path("/proc/net/tcp"), "tcp", "ipv4"),
        (Path("/proc/net/tcp6"), "tcp", "ipv6"),
        (Path("/proc/net/udp"), "udp", "ipv4"),
        (Path("/proc/net/udp6"), "udp", "ipv6"),
    ]
    by_inode: dict[str, dict[str, Any]] = {}
    for path, proto, family in tables:
        for row in parse_proc_net_table(path, proto, family):
            by_inode[row["inode"]] = row
    return by_inode


def socket_inodes_from_fd_links(fd_links: list[dict[str, Any]]) -> list[str]:
    inodes: list[str] = []
    for fd_link in fd_links:
        target = fd_link.get("target") or ""
        match = SOCKET_RE.fullmatch(target)
        if match:
            inodes.append(match.group(1))
    return inodes


def read_process_snapshot(pid: int, include_env: bool) -> dict[str, Any]:
    base = Path(f"/proc/{pid}")
    snapshot: dict[str, Any] = {
        "pid": pid,
        "cmdline": read_cmdline(pid),
        "status": safe_text(base / "status", strip=False),
        "stat": safe_text(base / "stat"),
        "io": safe_text(base / "io", strip=False),
        "limits": safe_text(base / "limits", strip=False),
        "cwd": safe_link(base / "cwd"),
        "exe": safe_link(base / "exe"),
        "fd_links": read_fd_links(pid),
    }
    if include_env:
        try:
            raw = (base / "environ").read_bytes()
            snapshot["environ"] = [
                item.decode(errors="replace") for item in raw.split(b"\0") if item
            ]
        except OSError:
            snapshot["environ"] = None
    return snapshot


@dataclass
class ToolProcess:
    name: str
    proc: subprocess.Popen[str]
    output: str


class Session:
    def __init__(
        self,
        output_dir: Path,
        events_path_override: str | None = None,
        summary_path_override: str | None = None,
    ) -> None:
        self.output_dir = output_dir
        self.output_dir.mkdir(parents=True, exist_ok=True)
        self.events_path = (
            Path(events_path_override).expanduser().resolve()
            if events_path_override
            else self.output_dir / "events.jsonl"
        )
        self.summary_path = (
            Path(summary_path_override).expanduser().resolve()
            if summary_path_override
            else self.output_dir / "summary.json"
        )
        self.events_path.parent.mkdir(parents=True, exist_ok=True)
        self.summary_path.parent.mkdir(parents=True, exist_ok=True)
        self._lock = threading.Lock()

    def write_json(self, name: str, data: Any) -> None:
        path = self.summary_path if name == "summary.json" else self.output_dir / name
        path.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n")

    def event(self, kind: str, **payload: Any) -> None:
        record = {"ts": utc_now(), "type": kind, **payload}
        with self._lock:
            with self.events_path.open("a", encoding="utf-8") as handle:
                handle.write(json.dumps(record, sort_keys=True) + "\n")


def console(message: str) -> None:
    print(message, file=sys.stderr, flush=True)


def spawn_strace(pid: int, output_dir: Path, trace_mode: str, string_bytes: int) -> ToolProcess | None:
    if shutil.which("strace") is None:
        return None
    trace_expr = "%network,%process,%file,%desc" if trace_mode == "broad" else "%network"
    cmd = [
        "strace",
        "-ff",
        "-tt",
        "-yy",
        "-xx",
        "-v",
        "-s",
        str(string_bytes),
        "-e",
        f"trace={trace_expr}",
        "-o",
        str(output_dir / "strace"),
        "-p",
        str(pid),
    ]
    proc = subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.PIPE, text=True)
    return ToolProcess("strace", proc, str(output_dir / "strace*"))


def spawn_command_under_strace(
    command: list[str],
    output_dir: Path,
    trace_mode: str,
    string_bytes: int,
) -> tuple[ToolProcess | None, Path]:
    pid_file = output_dir / "root.pid"
    if shutil.which("strace") is None:
        return None, pid_file
    trace_expr = "%network,%process,%file,%desc" if trace_mode == "broad" else "%network"
    wrapper = (
        "import os, sys; "
        "open(sys.argv[1], 'w', encoding='utf-8').write(str(os.getpid())); "
        "os.execvp(sys.argv[2], sys.argv[2:])"
    )
    cmd = [
        "strace",
        "-ff",
        "-tt",
        "-yy",
        "-xx",
        "-v",
        "-s",
        str(string_bytes),
        "-e",
        f"trace={trace_expr}",
        "-o",
        str(output_dir / "strace"),
        "python3",
        "-c",
        wrapper,
        str(pid_file),
        *command,
    ]
    proc = subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.PIPE, text=True)
    return ToolProcess("strace", proc, str(output_dir / "strace*")), pid_file


def spawn_tcpdump(output_dir: Path, bpf_filter: str | None) -> ToolProcess | None:
    if shutil.which("tcpdump") is None:
        return None
    cmd = ["tcpdump", "-i", "any", "-nn", "-s", "0", "-U", "-w", str(output_dir / "traffic.pcap")]
    if bpf_filter:
        cmd.extend(bpf_filter.split())
    proc = subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.PIPE, text=True)
    return ToolProcess("tcpdump", proc, str(output_dir / "traffic.pcap"))


def ebpf_network_program() -> str:
    return r"""
tracepoint:syscalls:sys_enter_socket
{
  printf("NET|%d|%d|%s|socket|family=%d type=%d protocol=%d\n",
         pid, tid, comm, args.family, args.type, args.protocol);
}

tracepoint:syscalls:sys_enter_bind
{
  printf("NET|%d|%d|%s|bind|fd=%d addrlen=%d\n",
         pid, tid, comm, args.fd, args.addrlen);
}

